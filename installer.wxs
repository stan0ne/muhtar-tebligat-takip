<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Muhtar Tebligat Takip"
           Manufacturer="Muhtarlik Tebligat Takip Sistemi"
           Version="1.5.4"
           UpgradeCode="B8E7C9A2-4F3D-4E5A-9C1B-2D6F8A3E7C9D"
           Scope="perMachine"
           Codepage="1254"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="Muhtarlik Tebligat Takip Sistemi" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <MajorUpgrade DowngradeErrorMessage="Daha yuksek bir surum zaten yuklu." />

    <Icon Id="AppIcon.ico" SourceFile="windows\runner\resources\app_icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="Muhtar Tebligat Takip">

        <Component Id="Exe" Guid="11111111-1111-1111-1111-111111111111">
          <File Id="ExeFile" Source="build\windows\x64\runner\Release\muhtar_tebligat_takip.exe" KeyPath="yes" />
        </Component>
        <Component Id="Dlls" Guid="22222222-2222-2222-2222-222222222222">
          <File Source="build\windows\x64\runner\Release\dartjni.dll" KeyPath="yes" />
          <File Source="build\windows\x64\runner\Release\flutter_windows.dll" />
          <File Source="build\windows\x64\runner\Release\pdfium.dll" />
          <File Source="build\windows\x64\runner\Release\printing_plugin.dll" />
          <File Source="build\windows\x64\runner\Release\sqlite3.dll" />
        </Component>

        <Directory Id="data" Name="data">
          <Component Id="Data" Guid="33333333-3333-3333-3333-333333333333">
            <File Source="build\windows\x64\runner\Release\data\app.so" KeyPath="yes" />
            <File Source="build\windows\x64\runner\Release\data\icudtl.dat" />
          </Component>

          <Directory Id="flutter_assets" Name="flutter_assets">
            <Component Id="Assets" Guid="44444444-4444-4444-4444-444444444444">
              <File Source="build\windows\x64\runner\Release\data\flutter_assets\AssetManifest.bin" KeyPath="yes" />
              <File Source="build\windows\x64\runner\Release\data\flutter_assets\FontManifest.json" />
              <File Source="build\windows\x64\runner\Release\data\flutter_assets\NOTICES.Z" />
              <File Source="build\windows\x64\runner\Release\data\flutter_assets\NativeAssetsManifest.json" />
            </Component>

            <Directory Id="dir_assets" Name="assets">
              <Directory Id="dir_fonts_inner" Name="fonts">
                <Component Id="ArialFont" Guid="55555555-5555-5555-5555-555555555555">
                  <File Source="build\windows\x64\runner\Release\data\flutter_assets\assets\fonts\arial.ttf" KeyPath="yes" />
                </Component>
              </Directory>
            </Directory>

            <Directory Id="dir_fonts" Name="fonts">
              <Component Id="MaterialFont" Guid="66666666-6666-6666-6666-666666666666">
                <File Source="build\windows\x64\runner\Release\data\flutter_assets\fonts\MaterialIcons-Regular.otf" KeyPath="yes" />
              </Component>
            </Directory>

            <Directory Id="dir_packages" Name="packages">
              <Directory Id="dir_cupertino" Name="cupertino_icons">
                <Directory Id="dir_cupertino_assets" Name="assets">
                  <Component Id="CupertinoFont" Guid="77777777-7777-7777-7777-777777777777">
                    <File Source="build\windows\x64\runner\Release\data\flutter_assets\packages\cupertino_icons\assets\CupertinoIcons.ttf" KeyPath="yes" />
                  </Component>
                </Directory>
              </Directory>
            </Directory>

            <Directory Id="dir_shaders" Name="shaders">
              <Component Id="Shaders" Guid="88888888-8888-8888-8888-888888888888">
                <File Source="build\windows\x64\runner\Release\data\flutter_assets\shaders\ink_sparkle.frag" KeyPath="yes" />
                <File Source="build\windows\x64\runner\Release\data\flutter_assets\shaders\stretch_effect.frag" />
              </Component>
            </Directory>

          </Directory>
        </Directory>

      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="Muhtar Tebligat Takip">
        <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
          <Shortcut Id="StartMenuShortcut"
                    Name="Muhtar Tebligat Takip"
                    Target="[INSTALLDIR]muhtar_tebligat_takip.exe"
                    Description="Muhtarlik Tebligat Takip Sistemi"
                    Icon="AppIcon.ico" />
          <RegistryValue Root="HKLM" Key="Software\MuhtarTebligatTakip" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
        <Shortcut Id="DesktopShortcut"
                  Name="Muhtar Tebligat Takip"
                  Target="[INSTALLDIR]muhtar_tebligat_takip.exe"
                  Description="Muhtarlik Tebligat Takip Sistemi"
                  Icon="AppIcon.ico" />
        <RegistryValue Root="HKLM" Key="Software\MuhtarTebligatTakip" Name="desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="Muhtar Tebligat Takip" Level="1">
      <ComponentRef Id="Exe" />
      <ComponentRef Id="Dlls" />
      <ComponentRef Id="Data" />
      <ComponentRef Id="Assets" />
      <ComponentRef Id="ArialFont" />
      <ComponentRef Id="MaterialFont" />
      <ComponentRef Id="CupertinoFont" />
      <ComponentRef Id="Shaders" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopFeature" Title="Masaustu Kisayolu" Level="1" AllowAbsent="yes">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />

  </Package>
</Wix>
